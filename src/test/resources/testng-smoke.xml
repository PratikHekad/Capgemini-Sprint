<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng-smoke.xml — Section 3.1
    Runs only @smoke-tagged Cucumber scenarios (TC-UI-01, TC-API-01, TC-E2E-03).
    Completes in under 3 minutes — used for fast pre-merge CI checks.

    To run:  mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-smoke.xml
-->
<suite name="NotesApp Smoke Suite" parallel="none" verbose="1">

    <test name="Smoke Scenarios">
        <classes>
            <class name="com.notesapp.runners.SmokeTestRunner"/>
        </classes>
    </test>

</suite>
