<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng.xml — Updated for Section 3
    Default suite used by: mvn test
    Cucumber scenarios run sequentially (safe for shared test data).
    PerformanceTest runs as a separate TestNG test after Cucumber.
-->
<suite name="NotesApp Full Suite" parallel="none" verbose="1">

    <!-- All Cucumber BDD scenarios -->
    <test name="Cucumber Tests">
        <classes>
            <class name="com.notesapp.runners.TestRunner"/>
        </classes>
    </test>

    <!-- Section 3.5 — Pure TestNG performance tests (no Cucumber) -->
    <test name="Performance Tests">
        <classes>
            <class name="com.notesapp.tests.performance.PerformanceTest"/>
        </classes>
    </test>

</suite>
